# ============================================
# Portafolio Crimson & Ember — Variables de Entorno
# ============================================
# Copia este archivo como .env.local para desarrollo
# o configúralo en tu hosting (Vercel, etc.) para producción.
#
# IMPORTANTE: NUNCA subas .env.local o .env.production al repositorio.
# Este archivo (.env.example) es la única excepción.
# ============================================

# ====================
# ADMIN PANEL
# ====================

# Contraseña maestra para acceder al panel /admin.
# Esta es la ÚNICA variable obligatoria. Sin ella, el admin no funciona.
# Puedes usar cualquier string seguro como contraseña.
ADMIN_SECRET=tu-contraseña-super-segura

# ====================
# GITHUB OAUTH (para auto-commit del admin)
# ====================
# Opcional — necesaria para que el admin panel pueda hacer commit y push
# automáticos a GitHub desde el entorno de producción.
#
# 1. Ve a GitHub Settings → Developer settings → OAuth Apps → New OAuth App
# 2. Homepage URL: https://tu-dominio.com
# 3. Authorization callback URL: https://tu-dominio.com/api/admin/github/callback
# 4. Copia el Client ID y genera un Client Secret

GITHUB_CLIENT_ID=tu-client-id
GITHUB_CLIENT_SECRET=tu-client-secret

# ====================
# GITHUB TOKEN (alternativa al OAuth)
# ====================
# Alternativa al flujo OAuth. Crea un Personal Access Token (classic)
# desde GitHub Settings → Developer settings → Personal access tokens.
# Requiere scope: 'repo' (para escribir en el repositorio).
#
# Si configuras esto + GITHUB_OWNER + GITHUB_REPO, el admin podrá
# hacer commits sin necesidad del flujo OAuth desde el navegador.
#
# GITHUB_TOKEN=ghp_tu-token-personal

# ====================
# REPOSITORIO (para auto-commit)
# ====================
# Requerido si usas GITHUB_TOKEN. Opcional si usas OAuth.
# Define el repositorio donde se harán los commits automáticos.

# GITHUB_OWNER=IDemonSan
# GITHUB_REPO=portafolio-crimson
# GITHUB_BRANCH=main

# ====================
# GITHUB USER-AGENT
# ====================
# Opcional. Identificador que se envía en el header User-Agent a la API de GitHub.
# Si no se define, se genera automáticamente como GITHUB_OWNER/GITHUB_REPO.
# Si tampoco hay owner/repo configurados, usa "brandonhuerta-portfolio".
# Puedes cambiarlo si GitHub te lo solicita o para identificar mejor tu app.
#
# GITHUB_USER_AGENT=mi-portafolio/1.0

# ====================
# RATE LIMITING (admin panel)
# ====================
# Configuración por defecto del rate limiter (no requiere variables de entorno):
# - Login: 5 intentos por ventana de 15 min, bloqueo de 30 min
# - Save: 20 guardados por ventana de 15 min
#
# Los límites se reinician al hacer deploy (Vercel) o al reiniciar el servidor.
# No hay variables de entorno para esto — se configura en src/lib/rate-limiter.ts
